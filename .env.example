# ============================================================
# MONDEGA DIGITAL — Variables de Entorno
# Copia este archivo como .env y llena los valores reales
# NUNCA subas el .env real a GitHub
# ============================================================

NODE_ENV=development

# ---- POSTGRESQL ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mondega_db
DB_USER=mondega_user
DB_PASSWORD=mondega_dev_password_change_in_prod
DB_SSL=false

# ---- MONGODB ----
MONGO_URI=mongodb://mondega_admin:mondega_dev_password_change_in_prod@localhost:27017/mondega_logs?authSource=admin

# ---- REDIS ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=mondega_dev_password_change_in_prod

# ---- KAFKA ----
KAFKA_BROKERS=localhost:9092

# ---- JWT / AUTH ----
# Genera: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64_different
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- CIFRADO AES-256-GCM ----
# Genera: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_here_000000000000000000000000000000000000000

# ---- FIREBASE — Proyecto: lentech-216a0 ----
FIREBASE_PROJECT_ID=lentech-216a0
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json
# Para CI/CD en base64: node -e "console.log(Buffer.from(require('fs').readFileSync('./firebase-service-account.json')).toString('base64'))"
FIREBASE_SERVICE_ACCOUNT_KEY_BASE64=CHANGE_ME

# Firebase cliente web (Console -> Configuracion -> Aplicaciones -> Web)
NEXT_PUBLIC_FIREBASE_API_KEY=CHANGE_ME
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=lentech-216a0.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=lentech-216a0
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=lentech-216a0.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=CHANGE_ME
NEXT_PUBLIC_FIREBASE_APP_ID=CHANGE_ME
NEXT_PUBLIC_FIREBASE_VAPID_KEY=CHANGE_ME

# ---- TWILIO (SMS) ----
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+CHANGE_ME

# ---- SENDGRID (Email) ----
SENDGRID_API_KEY=SG.CHANGE_ME
SENDGRID_FROM_EMAIL=noreply@mondega.com
SENDGRID_FROM_NAME=Mondega Digital

# ---- META / WHATSAPP BUSINESS ----
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME
WHATSAPP_ACCESS_TOKEN=CHANGE_ME

# ---- BLOCKCHAIN — POLYGON ----
POLYGON_RPC_URL=https://polygon-rpc.com
MONDEGA_COIN_ADDRESS=0xCHANGE_ME
TREASURY_PRIVATE_KEY=CHANGE_ME_USE_FIREBLOCKS_IN_PRODUCTION
TREASURY_ADDRESS=0xCHANGE_ME

# ---- KYC — JUMIO ----
JUMIO_API_TOKEN=CHANGE_ME
JUMIO_API_SECRET=CHANGE_ME
JUMIO_BASE_URL=https://netverify.com/api/v4
JUMIO_CALLBACK_URL=https://api.mondega.com/kyc/webhook

# ---- FX ORACLE ----
OPENEXCHANGERATES_APP_ID=CHANGE_ME
FIXER_API_KEY=CHANGE_ME

# ---- AML — CHAINALYSIS ----
CHAINALYSIS_API_KEY=CHANGE_ME
CHAINALYSIS_BASE_URL=https://public.chainalysis.com/api/v1

# ---- BANRURAL (Guatemala) ----
BANRURAL_API_URL=https://api.banrural.com.gt/v1
BANRURAL_API_KEY=CHANGE_ME
BANRURAL_MERCHANT_ID=CHANGE_ME
BANRURAL_WEBHOOK_SECRET=CHANGE_ME

# ---- SPEI / CoDi (Mexico) ----
SPEI_API_URL=https://api.banxico.org.mx/spei/v1
CODI_API_URL=https://api.banxico.org.mx/codi/v1
CODI_CERT_PATH=./certs/codi-client.crt
CODI_KEY_PATH=./certs/codi-client.key
OPENPAY_MERCHANT_ID=CHANGE_ME
OPENPAY_API_KEY=CHANGE_ME
OPENPAY_BASE_URL=https://api.openpay.mx/v1

# ---- CARD SERVICE — MARQETA ----
MARQETA_BASE_URL=https://sandbox.marqeta.com/v3
MARQETA_APP_TOKEN=CHANGE_ME
MARQETA_MASTER_TOKEN=CHANGE_ME

# ---- URLS INTERNAS (microservicios) ----
AUTH_SERVICE_URL=http://auth-service:3001
WALLET_SERVICE_URL=http://wallet-service:3002
FX_ENGINE_URL=http://fx-engine:3003
COMPLIANCE_URL=http://compliance:3004
NOTIFICATION_URL=http://notification:3005
FIAT_BRIDGE_URL=http://fiat-bridge:3006
CARD_SERVICE_URL=http://card-service:3007
TX_ENGINE_URL=http://tx-engine:8090

# ---- APPS FRONTEND ----
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:3001
