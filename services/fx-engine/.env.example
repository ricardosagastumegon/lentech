# ============================================================
# MONDEGA DIGITAL — FX Engine — Environment Variables
# ============================================================

NODE_ENV=development
PORT=3003

# ---- Redis (rate cache + quote lock storage) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ---- FX Rate Providers (cascade fallback) ----
# Provider 1 — Primary: https://openexchangerates.org (free: 1000 req/month)
OPENEXCHANGERATES_APP_ID=your_app_id

# Provider 2 — Secondary: https://fixer.io (free: 100 req/month)
FIXER_API_KEY=your_api_key

# Provider 3 — Tertiary: https://api.exchangerate.host (free, no key needed)
# No config needed

# ---- Rate Limiting ----
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ---- App Origins ----
APP_URL=http://localhost:3000
