# ============================================================
# MONDEGA DIGITAL — Compliance Service — Environment Variables
# ============================================================

NODE_ENV=development
PORT=3004

# ---- PostgreSQL ----
DATABASE_URL=postgresql://mondega_user:password@localhost:5432/mondega_db

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ---- Chainalysis (sanctions & OFAC screening) ----
# https://www.chainalysis.com — required for production
CHAINALYSIS_API_KEY=your_api_key

# ---- JWT (shared) ----
JWT_SECRET=your_64_byte_hex_secret
JWT_ISSUER=mondega.io

# ---- Internal Service Auth ----
INTERNAL_API_SECRET=your_internal_secret

# ---- Rate Limiting ----
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=30
