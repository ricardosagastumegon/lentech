# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3004
APP_URL=https://fiat-bridge.railway.app   # your Railway URL

# ── Database (Railway PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/len_fiat

# ── Redis (Railway Redis) ─────────────────────────────────────────────────────
REDIS_HOST=redis.railway.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Guatemala — Banrural (FIDEICOMISO, not pool account) ─────────────────────
# Legal model: LEN GT S.A. = fideicomitente, users = fideicomisarios
# Users deposit GTQ to their sub-account (1832-2383738-XXXX)
# Banrural is fiduciario — funds never belong to LEN
BANRURAL_API_KEY=           # from Banrural corporate banking agreement
BANRURAL_API_URL=https://api.banrural.com.gt
BANRURAL_FIDEICOMISO_ACCOUNT=1832-2383738-  # master fideicomiso prefix (+ user suffix)
WEBHOOK_SECRET_GT=          # shared secret for HMAC verification

# ── México — STP sub-CLABE (each user has their own CLABE) ───────────────────
# Legal model: each user's MXN stays in their STP sub-CLABE — not in LEN's account
# LEN emits MEXCOIN tokens as digital representation
# Production: GET /clabe/create from Conekta or direct STP API
STP_CLABE_PREFIX=646180     # STP institution prefix (Conekta = 646180)
CODI_BASE_URL=https://ccen.banxico.org.mx
CODI_CERT_PATH=/certs/codi.pem
CODI_KEY_PATH=/certs/codi.key
WEBHOOK_SECRET_MX=          # shared secret for HMAC verification

# OXXO Pay via OpenPay (alternative cash deposit MX)
OXXO_API_KEY=
OXXO_API_URL=https://api.openpay.mx

# ── Honduras — BAC Honduras ───────────────────────────────────────────────────
BAC_API_KEY=                # from BAC corporate banking agreement
BAC_API_SECRET=             # for request signing
BAC_API_URL=https://api.baccredomatic.com.hn
BAC_LEN_POOL_ACCOUNT=       # LEN's pool account at BAC HN (3090-0000-HN-LEN)
WEBHOOK_SECRET_HN=          # shared secret for HMAC verification

# ── Internal service communication ────────────────────────────────────────────
WALLET_SERVICE=https://wallet-service.railway.internal
WEB_APP_URL=https://len.app
INTERNAL_API_KEY=           # used by wallet-service to call fiat-bridge
