# ============================================================
# MONDEGA DIGITAL — Fiat Bridge — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env
# ============================================================

NODE_ENV=development
PORT=3006
APP_URL=http://localhost:3000

# ---- PostgreSQL ----
DATABASE_URL=postgresql://mondega_user:password@localhost:5432/mondega_db

# ---- Redis (Bull queues) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ---- JWT (shared with auth-service) ----
JWT_SECRET=your_64_byte_hex_secret
JWT_ISSUER=mondega.io

# ---- Encryption (shared across services) ----
ENCRYPTION_KEY=your_64_char_hex_key

# ---- Banrural Guatemala ----
# Contact: https://www.banrural.com.gt — API sandbox credentials
BANRURAL_API_URL=https://api-sandbox.banrural.com.gt/v1
BANRURAL_API_KEY=your_api_key
BANRURAL_API_SECRET=your_api_secret
BANRURAL_MERCHANT_ID=your_merchant_id
MONDEGA_ACCOUNT_GT=your_banrural_account_number

# ---- STP / SPEI Mexico ----
# Contact: https://stpmex.com — Sistema de Transferencias y Pagos
SPEI_STP_EMPRESA=your_empresa_id
SPEI_STP_API_KEY=your_api_key
SPEI_STP_SIGNING_KEY_PATH=/opt/mondega/stp-key.pem
MONDEGA_CLABE_MX=000000000000000000

# ---- BAC Credomatic Honduras ----
# Contact: https://www.baccredomatic.com — API sandbox
BAC_API_URL=https://sandbox.baccredomatic.com/v1
BAC_API_KEY=your_api_key
BAC_MERCHANT_ID=your_merchant_id
MONDEGA_ACCOUNT_HN=your_bac_account_number

# ---- Webhook Signing ----
# Used to verify incoming webhook authenticity from bank providers
WEBHOOK_SECRET=your_webhook_signing_secret

# ---- Internal Service Auth ----
INTERNAL_API_SECRET=your_internal_secret

# ---- Rate Limiting ----
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=30
