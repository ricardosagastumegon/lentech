# ============================================================
# MONDEGA DIGITAL — Card Service — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env
# ============================================================

NODE_ENV=development
PORT=3007
APP_URL=http://localhost:3000

# ---- PostgreSQL ----
DATABASE_URL=postgresql://mondega_user:password@localhost:5432/mondega_db

# ---- JWT (shared with auth-service) ----
JWT_SECRET=your_64_byte_hex_secret
JWT_ISSUER=mondega.io

# ---- Encryption (shared across services) ----
ENCRYPTION_KEY=your_64_char_hex_key

# ---- Pomelo (Mastercard International Issuing) ----
# Sandbox: https://dashboard.sandbox.pomelo.la
# Production: https://dashboard.pomelo.la
# Apply at: https://pomelo.la/contacto
POMELO_API_URL=https://api.sandbox.pomelo.la
POMELO_CLIENT_ID=your_client_id
POMELO_CLIENT_SECRET=your_client_secret
POMELO_AUDIENCE=https://api.pomelo.la

# ---- Rate Limiting ----
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=30

# ---- Internal Service Auth ----
INTERNAL_API_SECRET=your_internal_secret
