# ============================================================
# MONDEGA DIGITAL — Notification Service — Environment Variables
# ============================================================

NODE_ENV=development
PORT=3005

# ---- Redis (Bull queues) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ---- Twilio (SMS + WhatsApp OTP) ----
# https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+15005550006

# ---- WhatsApp Business API (Meta Cloud API) ----
# https://developers.facebook.com/apps/
WHATSAPP_API_TOKEN=your_meta_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ---- SendGrid (Transactional Email) ----
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@mondega.io

# ---- Firebase Cloud Messaging (Push Notifications) ----
# Service account JSON — path or inline JSON
FIREBASE_SERVICE_ACCOUNT_PATH=/opt/mondega/firebase-service-account.json
