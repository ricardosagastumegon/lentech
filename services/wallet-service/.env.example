# ============================================================
# MONDEGA DIGITAL — Wallet Service — Environment Variables
# ============================================================

NODE_ENV=development
PORT=3002

# ---- PostgreSQL ----
DATABASE_URL=postgresql://mondega_user:password@localhost:5432/mondega_db

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ---- JWT (shared with auth-service) ----
JWT_SECRET=your_64_byte_hex_secret
JWT_ISSUER=mondega.io

# ---- Encryption (shared across services) ----
ENCRYPTION_KEY=your_64_char_hex_key

# ---- Blockchain (Celo / Polygon) ----
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_key
MONDEGA_CONTRACT_ADDRESS=0x...
# CAUTION: Only for development — in production use Fireblocks MPC
DEPLOYER_PRIVATE_KEY=0x...

# ---- Inter-Service ----
AUTH_SERVICE_URL=http://localhost:3001
INTERNAL_API_SECRET=your_internal_secret

# ---- App Origins ----
APP_URL=http://localhost:3000
